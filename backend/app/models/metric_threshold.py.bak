"""
指标阈值设置模型 - 映射到 alert_rules 表
"""
from sqlalchemy import Column, Integer, Float, String, DateTime, Text, JSON
from sqlalchemy.sql import func
from app.database import Base


class MetricThreshold(Base):
    """指标阈值配置表 - 映射到alert_rules"""
    __tablename__ = "alert_rules"
    __table_args__ = {'extend_existing': True}
    
    id = Column(Integer, primary_key=True, index=True)
    shop_id = Column(Integer, default=1)
    rule_type = Column(String(50))
    name = Column(String(100))
    description = Column(Text)
    condition = Column(JSON)
    is_active = Column(Integer, default=1)
    severity = Column(String(20), default="warning")
    check_frequency = Column(String(20), default="daily")
    last_triggered_at = Column(DateTime, nullable=True)
    created_at = Column(DateTime, server_default=func.now())
