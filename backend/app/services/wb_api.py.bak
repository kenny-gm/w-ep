"""
WB API 对接服务
按 dev.wildberries.ru 官方文档实现，每个分类独立限流配置
"""
import httpx
import time
import json
from typing import Optional, Dict, Any, List
from app.config import settings


class RateLimiter:
    """频率限制器"""
    
    def __init__(
        self,
        limit: int,          # 时间窗口内最大请求数
        interval: float,     # 最小请求间隔（秒）
        burst: int,          # 允许突发请求数
        window_seconds: int = 60  # 时间窗口（秒）
    ):
        self.limit = limit
        self.interval = interval
        self.burst = burst
        self.window_seconds = window_seconds
        
        # 状态
        self._request_times: List[float] = []  # 请求时间记录
        self._last_request_time: float = 0
    
    def wait_if_needed(self) -> None:
        """必要时等待"""
        current_time = time.time()
        
        # 1. 确保最小间隔
        time_since_last = current_time - self._last_request_time
        if time_since_last < self.interval:
            time.sleep(self.interval - time_since_last)
        
        # 2. 清理过期的请求记录
        cutoff_time = current_time - self.window_seconds
        self._request_times = [t for t in self._request_times if t > cutoff_time]
        
        # 3. 检查是否达到限制
        if len(self._request_times) >= self.limit:
            # 等待到最早的请求过期
            oldest_request = min(self._request_times)
            wait_time = oldest_request + self.window_seconds - current_time
            if wait_time > 0:
                time.sleep(wait_time)
                self._request_times = []  # 重置
        
        # 4. 记录本次请求
        self._request_times.append(time.time())
        self._last_request_time = time.time()
    
    def add_cost(self, multiplier: int) -> None:
        """增加请求消耗（如 409 错误）"""
        for _ in range(multiplier - 1):
            self._request_times.append(time.time())


class WBAPIClient:
    """Wildberries API 客户端"""
    
    # ========== API 域名映射（按文档硬编码）==========
    API_DOMAINS = {
        "common": "https://common-api.wildberries.ru",
        "content": "https://content-api.wildberries.ru",
        "marketplace": "https://marketplace-api.wildberries.ru",
        "analytics": "https://seller-analytics-api.wildberries.ru",
        "statistics": "https://statistics-api.wildberries.ru",
        "promotion": "https://advert-api.wildberries.ru",
        "finance": "https://finance-api.wildberries.ru",
    }
    
    # ========== 每个分类的 Rate Limits（按用户要求设置）==========
    RATE_LIMITS = {
        # 公共 API - 基础查询
        "common": RateLimiter(
            limit=300,       # 300请求/分钟
            interval=0.2,    # 200ms 最小间隔
            burst=20,        # 突发20个请求
            window_seconds=60
        ),
        
        # 商品内容 - 1分钟100次，间隔600毫秒
        "content": RateLimiter(
            limit=100,       # 100请求/分钟
            interval=0.6,    # 600ms 间隔
            burst=10,        # 突发10个
            window_seconds=60
        ),
        
        # 订单库存 - 高频操作
        "marketplace": RateLimiter(
            limit=300,       # 300请求/分钟
            interval=0.2,    # 200ms 间隔
            burst=20,        # 突发20个
            window_seconds=60
        ),
        
        # 分析报表 - 1分钟3次，间隔20秒
        "analytics": RateLimiter(
            limit=3,         # 3请求/分钟
            interval=20.0,   # 20秒 间隔
            burst=1,         # 不允许突发
            window_seconds=60
        ),
        
        # 统计报表 - 1分钟3次，间隔20秒
        "statistics": RateLimiter(
            limit=3,         # 3请求/分钟
            interval=20.0,   # 20秒 间隔
            burst=1,         # 不允许突发
            window_seconds=60
        ),
        
        # 广告推广 - 1分钟3次，间隔20秒
        "promotion": RateLimiter(
            limit=3,         # 3请求/分钟
            interval=20.0,   # 20秒 间隔
            burst=1,         # 不允许突发
            window_seconds=60
        ),
        
        # 财务 - 敏感操作，限流严格
        "finance": RateLimiter(
            limit=60,        # 60请求/分钟
            interval=1.0,    # 1秒 间隔
            burst=5,         # 突发5个
            window_seconds=60
        ),
    }
    
    # 错误码对应的请求消耗倍数（按文档）
    ERROR_COST_MULTIPLIER = {
        409: 5,   # 状态更新错误，计为5个请求
        429: 5,   # 限流错误，计为5个请求
    }
    
    def __init__(self, api_token: str):
        self.api_token = api_token
        self.headers = {
            "Authorization": api_token,
            "Content-Type": "application/json"
        }
    
    def _get_limiter(self, category: str) -> RateLimiter:
        """获取指定分类的限流器"""
        if category not in self.RATE_LIMITS:
            # 默认使用 marketplace 的配置
            return self.RATE_LIMITS["marketplace"]
        return self.RATE_LIMITS[category]
    
    import logging
logging.basicConfig(level=logging.DEBUG)

def _request(
        self,
        method: str,
        category: str,
        endpoint: str,
        params: Optional[Dict] = None,
        json_data: Optional[Dict] = None,
        retry: int = 3
    ) -> Dict[str, Any]:
        """发送 API 请求（带分类限流控制和重试机制）"""
        url = f"{self.API_DOMAINS.get(category, '')}{endpoint}"
        limiter = self._get_limiter(category)
        
        last_error = None
        
        for attempt in range(retry):
            try:
                # 频率控制
                limiter.wait_if_needed()
                
                # 发送请求
                with httpx.Client(timeout=30.0) as client:
                    if method == "GET":
                        response = client.get(url, headers=self.headers, params=params)
                    elif method == "POST":
                        response = client.post(url, headers=self.headers, params=params, json=json_data)
                    elif method == "PUT":
                        response = client.put(url, headers=self.headers, params=params, json=json_data)
                    elif method == "DELETE":
                        response = client.delete(url, headers=self.headers, params=params)
                    else:
                        raise ValueError(f"Unsupported method: {method}")
                
                # 处理响应
                if response.status_code == 200:
                    return response.json()
                elif response.status_code == 204:
                    return {}
                elif response.status_code == 429:
                    # 限流，等待后重试
                    print(f"Rate limited (429), waiting... attempt {attempt + 1}/{retry}")
                    limiter.add_cost(self.ERROR_COST_MULTIPLIER.get(429, 5))
                    time.sleep(60)  # 等待1分钟
                    continue
                elif response.status_code == 409:
                    # 冲突，增加消耗
                    limiter.add_cost(self.ERROR_COST_MULTIPLIER.get(409, 5))
                    if attempt < retry - 1:
                        time.sleep(1)
                        continue
                    raise Exception(f"API 请求失败 [{response.status_code}]: {response.text}")
                elif response.status_code == 401:
                    raise Exception(f"API 认证失败 (401): Token 无效或已过期")
                elif response.status_code == 403:
                    raise Exception(f"API 权限不足 (403): {response.text[:200]}")
                elif response.status_code == 404:
                    # 端点不存在
                    raise Exception(f"API 端点不存在 [404]: {url}")
                else:
                    raise Exception(f"API 请求失败 [{response.status_code}]: {response.text[:200]}")
                    
            except httpx.TimeoutException:
                last_error = Exception(f"API 请求超时")
                if attempt < retry - 1:
                    time.sleep(2)
                    continue
            except httpx.RequestError as e:
                last_error = Exception(f"网络请求错误: {e}")
                if attempt < retry - 1:
                    time.sleep(2)
                    continue
            except Exception as e:
                if "401" in str(e) or "403" in str(e) or "404" in str(e):
                    raise
                last_error = e
                if attempt < retry - 1:
                    time.sleep(2)
                    continue
        
        raise last_error or Exception("API 请求失败")
    
    # ========== 连接测试 ==========
    def ping(self, category: str = "common") -> bool:
        """测试连接 - 使用 seller-info 接口验证"""
        try:
            result = self._request("GET", "common", "/api/v1/seller-info")
            return bool(result)
        except Exception as e:
            print(f"WB API ping failed: {e}")
            return False

def get_seller_info(self) -> Dict[str, Any]:
        """获取卖家信息"""
        return self._request("GET", "common", "/api/v1/seller-info")
    
    # ========== 商品相关（content 分类）==========
    def get_products(self, limit: int = 100, offset: int = 0, locale: str = "ru") -> List[Dict[str, Any]]:
        """
        获取商品列表
        API: POST https://content-api.wildberries.ru/content/v2/get/cards/list
        限流：content 分类 - 100请求/分钟, 600ms间隔
        
        Args:
            limit: 每次获取数量 (最大100)
            offset: 偏移量，用于分页
            locale: 语言 (ru/zh/en)
        """
        try:
            print(f"[WB API] 调用get_products: limit={limit}, offset={offset}, locale={locale}")
            print(f"[WB API] API Token (前10位): {self.api_token[:10]}...")
            response = self._request(
                "POST", "content", "/content/v2/get/cards/list",
                json_data={"limit": limit, "offset": offset, "locale": locale}
            )
            print(f"[WB API] API响应: {response}")
            cards = response.get("cards", [])
            print(f"[WB API] 返回产品数量: {len(cards)}")
            if cards:
                print(f"[WB API] 第一个产品: nmID={cards[0].get('nmID')}, vendorCode={cards[0].get('vendorCode')}")
            return cards
        except Exception as e:
            print(f"[WB API] get_products错误: {e}")
            import traceback
            traceback.print_exc()
            return []
    
    def get_products_all(self, locale: str = "ru") -> List[Dict[str, Any]]:
        """
        获取所有商品（自动分页）
        """
        all_products = []
        offset = 0
        limit = 100
        
        while True:
            products = self.get_products(limit=limit, offset=offset, locale=locale)
            all_products.extend(products)
            
            if len(products) < limit:
                break
            offset += limit
        
        return all_products
    
    def get_product_by_nmId(self, nm_id: int) -> Optional[Dict[str, Any]]:
        """
        根据nmId获取单个商品详情
        """
        try:
            response = self._request(
                "POST", "content", "/content/v2/get/cards/list",
                json_data={"nmId": nm_id}
            )
            cards = response.get("cards", [])
            return cards[0] if cards else None
        except Exception:
            return None
    
    def get_categories(self) -> List[Dict[str, Any]]:
        """获取类目列表"""
        response = self._request("GET", "content", "/content/v2/object/parent/all")
        return response or []
    
    # ========== 订单相关（marketplace 分类）==========
    def get_new_orders(self) -> List[Dict[str, Any]]:
        """
        获取新订单
        限流：marketplace 分类 - 300请求/分钟, 200ms间隔
        """
        response = self._request("GET", "marketplace", "/api/v3/orders/new")
        return response.get("orders", [])
    
    def get_orders(self, limit: int = 1000, offset: int = 0) -> List[Dict[str, Any]]:
        """
        获取订单列表
        限流：marketplace 分类 - 300请求/分钟, 200ms间隔
        """
        response = self._request(
            "GET", "marketplace", "/api/v3/orders",
            params={"limit": limit, "offset": offset}
        )
        return response.get("orders", [])
    
    # ========== 库存相关（marketplace 分类）==========
    def get_warehouses(self) -> List[Dict[str, Any]]:
        """获取仓库列表"""
        response = self._request("GET", "marketplace", "/api/v3/warehouses")
        return response or []
    
    def get_stock(self, warehouse_id: str, nm_ids: Optional[List[str]] = None) -> List[Dict[str, Any]]:
        """
        获取库存
        限流：marketplace 分类 - 300请求/分钟, 200ms间隔
        """
        json_data = {"items": []}
        if nm_ids:
            json_data["items"] = [{"nmId": nm_id} for nm_id in nm_ids]
        
        response = self._request(
            "POST", "marketplace",
            f"/api/v3/stocks/{warehouse_id}",
            json_data=json_data
        )
        return response.get("items", [])
    
    # ========== 财务相关（statistics/finance 分类）==========
    def get_finance_balance(self) -> Dict[str, Any]:
        """
        获取余额
        限流：finance 分类 - 60请求/分钟, 1秒间隔
        """
        return self._request("GET", "finance", "/api/v1/finance/balance")
    
    def get_supplier_report(self, date_from: str, date_to: str) -> List[Dict[str, Any]]:
        """
        获取销售报表 - 使用正确的API端点
        限流：statistics 分类 - 3请求/分钟, 20秒间隔
        
        注意：WB API使用POST请求，日期格式为YYYY-MM-DD
        """
        try:
            # 尝试使用reportDetailByPeriod端点
            response = self._request(
                "POST", "statistics", "/api/v1/supplier/reportDetailByPeriod",
                json_data={"dateFrom": date_from, "dateTo": date_to}
            )
            return response if response else []
        except Exception as e:
            print(f"Supplier report API error: {e}")
            return []
    
    def get_sales_report(self, date_from: str, date_to: str) -> List[Dict[str, Any]]:
        """
        获取销售报告（替代方案）
        """
        try:
            response = self._request(
                "POST", "analytics", "/api/v2/nm-report",
                json_data={
                    "brandNames": [],
                    "objectIDs": [],
                    "nmIDs": [],
                    "timezone": "Europe/Moscow",
                    "period": {
                        "begin": date_from,
                        "end": date_to
                    }
                }
            )
            return response.get("data", {}).get("cards", []) if response else []
        except Exception as e:
            print(f"Sales report API error: {e}")
            return []
    
    # ========== 广告相关（promotion 分类）==========
    def get_adverts(self, statuses: Optional[List[int]] = None) -> List[Dict[str, Any]]:
        """
        获取广告列表
        API: GET https://advert-api.wildberries.ru/api/advert/v2/adverts
        限流：promotion 分类 - 3请求/分钟, 20秒间隔
        
        Args:
            statuses: 广告状态筛选 [-1:草稿, 4:暂停, 8:投放中]
        """
        try:
            # 如果没有提供ids，先获取所有广告活动
            # 使用 ids 参数查询指定广告的详情
            params = {}
            
            response = self._request("GET", "promotion", "/api/advert/v2/adverts", params=params)
            return response if isinstance(response, list) else []
        except Exception as e:
            print(f"Adverts API error: {e}")
            return []
    
    def get_ad_stats(
        self,
        ids: Optional[List[int]] = None,
        date_from: Optional[str] = None,
        date_to: Optional[str] = None
    ) -> List[Dict[str, Any]]:
        """
        获取广告统计
        API: GET https://advert-api.wildberries.ru/api/advert/v1/reports
        限流：promotion 分类 - 3请求/分钟, 20秒间隔
        
        Args:
            ids: 广告活动ID列表（逗号分隔）
            date_from: 开始日期 YYYY-MM-DD
            date_to: 结束日期 YYYY-MM-DD
        """
        try:
            if not ids:
                # 先获取广告列表
                adverts = self.get_adverts()
                ids = [adv.get("id") for adv in adverts if adv.get("id")]
            
            if not ids:
                return []
            
            # 使用GET请求，ids为逗号分隔的字符串
            params = {
                "ids": ",".join(map(str, ids))
            }
            if date_from:
                params["dateFrom"] = date_from
            if date_to:
                params["dateTo"] = date_to
            
            response = self._request("GET", "promotion", "/api/advert/v1/reports", params=params)
            return response if isinstance(response, list) else response.get("data", [])
        except Exception as e:
            print(f"Ad stats API error: {e}")
            return []
    
    def get_sales_history(self, date_from: str, date_to: str) -> List[Dict[str, Any]]:
        """
        获取销售历史 - 使用analytics/v3/sales-funnel/products/history端点
        API: POST https://seller-analytics-api.wildberries.ru/api/analytics/v3/sales-funnel/products/history
        限流：analytics 分类 - 3请求/分钟, 20秒间隔
        
        Args:
            date_from: 开始日期 YYYY-MM-DD
            date_to: 结束日期 YYYY-MM-DD
        """
        try:
            response = self._request(
                "POST", "analytics", "/api/analytics/v3/sales-funnel/products/history",
                json_data={
                    "period": {
                        "begin": date_from,
                        "end": date_to
                    }
                }
            )
            return response.get("data", {}).get("products", []) if response else []
        except Exception as e:
            print(f"Sales history API error: {e}")
            return []
    
    # ========== 分析相关（analytics 分类）==========
    def get_sales_funnel(self, date_from: str, date_to: str) -> Dict[str, Any]:
        """
        获取销售漏斗
        API: POST https://seller-analytics-api.wildberries.ru/api/v1/sales-funnel
        限流：analytics 分类 - 3请求/分钟, 20秒间隔
        """
        response = self._request(
            "POST", "analytics", "/api/v1/sales-funnel",
            json_data={"dateFrom": date_from, "dateTo": date_to}
        )
        return response or {}
    
    def get_product_stats(self, date_from: str, date_to: str, nm_ids: Optional[List[int]] = None) -> List[Dict[str, Any]]:
        """
        获取产品统计 - 使用nm-report API
        API: POST https://seller-analytics-api.wildberries.ru/api/v2/nm-report
        限流：analytics 分类 - 3请求/分钟, 20秒间隔
        
        Args:
            date_from: 开始日期 YYYY-MM-DD
            date_to: 结束日期 YYYY-MM-DD
            nm_ids: 产品ID列表（可选，不传则返回所有）
        """
        try:
            json_data = {
                "brandNames": [],
                "objectIDs": [],
                "nmIDs": nm_ids or [],
                "timezone": "Europe/Moscow",
                "period": {
                    "begin": date_from,
                    "end": date_to
                }
            }
            
            response = self._request(
                "POST", "analytics", "/api/v2/nm-report",
                json_data=json_data
            )
            return response.get("data", {}).get("cards", []) if response else []
        except Exception as e:
            print(f"Product stats API error: {e}")
            return []
    
    # ========== 价格相关（content 分类）==========
    def set_prices(self, items: List[Dict]) -> Dict[str, Any]:
        """
        设置价格
        限流：content 分类 - 100请求/分钟, 600ms间隔
        """
        return self._request(
            "POST", "content", "/api/v2/goods/prices",
            json_data={"items": items}
        )
