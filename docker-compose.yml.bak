version: '3.8'

services:
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: wb-erp-backend
    ports:
      - '8000:8000'
    volumes:
      - ./backend:/app
      - ./logs:/app/logs
    environment:
      - ENVIRONMENT=production
      - TZ=Asia/Shanghai
    restart: unless-stopped
    networks:
      - wb-erp-network

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: wb-erp-frontend
    ports:
      - '80:80'
    depends_on:
      - backend
    environment:
      - TZ=Asia/Shanghai
    restart: unless-stopped
    networks:
      - wb-erp-network

networks:
  wb-erp-network:
    driver: bridge
