<template>
  <div class="cpm-table-card">
    <div class="cpm-search-header">
      <h3>CPM搜索广告</h3>
      <div class="header-info">
        <span class="total-cost">总花费: {{ formatNumber(totalCost) }} ₽</span>
      </div>
    </div>
    
    <el-table 
      :data="tableData" 
      :expand-row-keys="expandedRows"
      row-key="date"
      @expand-change="handleExpandChange"
      stripe
      style="width: 100%; min-width: 900px;"
      :show-header="true"
      :fit="true"
    >
      <el-table-column type="expand" fixed>
        <template #default="props">
          <div class="expand-content" v-if="props.row.platforms">
            <div class="platform-tabs">
              <el-radio-group v-model="selectedPlatform" size="small">
                <el-radio-button label="all">全部</el-radio-button>
                <el-radio-button label="web">Web</el-radio-button>
                <el-radio-button label="android">Android</el-radio-button>
                <el-radio-button label="ios">iOS</el-radio-button>
              </el-radio-group>
            </div>
            <div class="platform-data">
              <template v-if="selectedPlatform === 'all'">
                <div class="platform-row" v-for="pf in ['web', 'android', 'ios']" :key="pf">
                  <span class="pf-name">{{ platformName(pf) }}</span>
                  <span class="pf-impressions">曝光: {{ formatNumber(getPlatformValue(props.row, pf, 'impressions')) }}</span>
                  <span class="pf-visitors">访客: {{ formatNumber(getPlatformValue(props.row, pf, 'visitors')) }}</span>
                  <span class="pf-cost">花费: {{ formatNumber(getPlatformValue(props.row, pf, 'cost')) }} ₽</span>
                  <span class="pf-orders">订单: {{ formatNumber(getPlatformValue(props.row, pf, 'orders')) }}</span>
                </div>
              </template>
              <template v-else>
                <div class="platform-detail">
                  <div class="detail-row">
                    <span class="label">曝光 (impressions)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'impressions')) }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">访客 (visitors)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'visitors')) }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">花费 (cost)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'cost')) }} ₽</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">订单 (orders)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'orders')) }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">购物车 (atbs)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'cart_count')) }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">加购率</span>
                    <span class="value">{{ getPlatformValue(props.row, selectedPlatform, 'visitors') > 0 ? (getPlatformValue(props.row, selectedPlatform, 'cart_count') / getPlatformValue(props.row, selectedPlatform, 'visitors') * 100).toFixed(1) + '%' : '0.0%' }}</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">花费 (cost)</span>
                    <span class="value">{{ formatNumber(getPlatformValue(props.row, selectedPlatform, 'sales')) }} ₽</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">CTR</span>
                    <span class="value">{{ getPlatformValue(props.row, selectedPlatform, 'ctr').toFixed(2) }}%</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">转化率</span>
                    <span class="value">{{ getPlatformValue(props.row, selectedPlatform, 'conversion_rate').toFixed(2) }}%</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">CPM</span>
                    <span class="value">{{ calcCpm(props.row, selectedPlatform) }} ₽</span>
                  </div>
                  <div class="detail-row">
                    <span class="label">CPC</span>
                    <span class="value">{{ calcCpc(props.row, selectedPlatform) }} ₽</span>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </template>
      </el-table-column>
      
      <el-table-column prop="date" label="日期" min-width="110" />
      <el-table-column label="曝光" align="right" min-width="90">
        <template #default="props">
          {{ formatNumber(props.row.impressions) }}
        </template>
      </el-table-column>
      <el-table-column label="访客" align="right" min-width="80">
        <template #default="props">
          {{ formatNumber(props.row.visitors) }}
        </template>
      </el-table-column>
      <el-table-column label="花费" align="right" min-width="120">
        <template #default="props">
          {{ formatNumber(props.row.cost) }} ₽
        </template>
      </el-table-column>
      <el-table-column label="订单" align="right" min-width="70">
        <template #default="props">
          {{ formatNumber(props.row.orders) }}
        </template>
      </el-table-column>
      <el-table-column label="购物车" align="right" min-width="80">
        <template #default="props">
          {{ formatNumber(props.row.cart_count) }}
        </template>
      </el-table-column>
      <el-table-column label="加购率" align="right" min-width="80">
        <template #default="props">
          {{ props.row.visitors > 0 ? (props.row.cart_count / props.row.visitors * 100).toFixed(1) : '0.0' }}%
        </template>
      </el-table-column>
      <el-table-column label="CTR" align="right" min-width="70">
        <template #default="props">
          {{ props.row.ctr.toFixed(2) }}%
        </template>
      </el-table-column>
      <el-table-column label="转化" align="right" min-width="70">
        <template #default="props">
          {{ props.row.conversion_rate.toFixed(2) }}%
        </template>
      </el-table-column>
      <el-table-column label="CPM" align="right" min-width="90">
        <template #default="props">
          {{ calcCpm(props.row) }} ₽
        </template>
      </el-table-column>
      <el-table-column label="CPC" align="right" min-width="90">
        <template #default="props">
          {{ calcCpc(props.row) }} ₽
        </template>
      </el-table-column>
    </el-table>
  </div>
</template>

<script setup>
import { ref, computed, watch } from 'vue'

const props = defineProps({
  data: {
    type: Array,
    default: () => []
  }
})

const expandedRows = ref([])
const selectedPlatform = ref('all')

// 聚合每日数据（按平台）
const tableData = computed(() => {
  const dailyMap = {}
  
  for (const item of props.data) {
    const date = item.record_date ? item.record_date.split(' ')[0] : item.date
    const platform = item.platform || 'web'
    
    if (!dailyMap[date]) {
      dailyMap[date] = {
        date,
        impressions: 0,
        visitors: 0,
        cost: 0,
        orders: 0,
        sales: 0,
        cart_count: 0,
        platforms: { web: null, android: null, ios: null }
      }
    }
    
    dailyMap[date].impressions += item.impressions || 0
    dailyMap[date].visitors += item.visitors || 0
    dailyMap[date].cost += item.cost || 0
    dailyMap[date].orders += item.order_count || 0
    dailyMap[date].sales += item.sales || 0
    dailyMap[date].cart_count += item.cart_count || 0
    
    // 保存平台明细
    if (!dailyMap[date].platforms[platform]) {
      dailyMap[date].platforms[platform] = {
        impressions: item.impressions || 0,
        visitors: item.visitors || 0,
        cost: item.cost || 0,
        orders: item.order_count || 0,
        sales: item.sales || 0,
        ctr: item.ctr || 0,
        conversion_rate: item.conversion_rate || 0,
        cart_count: item.cart_count || 0
      }
    }
  }
  
  const result = Object.values(dailyMap).map(day => ({
      ...day,
      ctr: day.impressions > 0 ? (day.visitors / day.impressions * 100) : 0,
      conversion_rate: day.visitors > 0 ? (day.orders / day.visitors * 100) : 0
    }))
    
    return result.sort((a, b) => new Date(b.date) - new Date(a.date))
})

const totalCost = computed(() => {
  return tableData.value.reduce((sum, row) => sum + row.cost, 0)
})

function getPlatformValue(row, platform, field) {
  if (!row.platforms || !row.platforms[platform]) return 0
  return row.platforms[platform][field] || 0
}

function calcCpm(row, platform = null) {
  let impressions, cost
  if (platform && platform !== 'all') {
    impressions = getPlatformValue(row, platform, 'impressions')
    cost = getPlatformValue(row, platform, 'cost')
  } else {
    impressions = row.impressions
    cost = row.cost
  }
  if (!impressions) return '0.00'
  return (cost / impressions * 1000).toFixed(2)
}

function calcCpc(row, platform = null) {
  let visitors, cost
  if (platform && platform !== 'all') {
    visitors = getPlatformValue(row, platform, 'visitors')
    cost = getPlatformValue(row, platform, 'cost')
  } else {
    visitors = row.visitors
    cost = row.cost
  }
  if (!visitors) return '0.00'
  return (cost / visitors).toFixed(2)
}

function platformName(pf) {
  const names = { web: 'Web', android: 'Android', ios: 'iOS' }
  return names[pf] || pf
}

function handleExpandChange(row) {
  const idx = expandedRows.value.indexOf(row.date)
  if (idx >= 0) {
    expandedRows.value.splice(idx, 1)
  } else {
    expandedRows.value.push(row.date)
  }
}

function formatNumber(n) {
  if (!n && n !== 0) return '0'
  return parseFloat(n.toString().replace(/,/g, '')).toLocaleString('ru-RU')
}
</script>

<style scoped>
.cpm-table-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.cpm-table-card :deep(.el-table) {
  table-layout: auto;
  overflow-x: auto;
  max-width: none;
}

.cpm-table-card :deep(.el-table__body-wrapper) {
  overflow-x: auto;
}

.cpm-table-card :deep(.cell) {
  white-space: nowrap;
}

.cpm-search-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.cpm-search-header h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
}

.total-cost {
  font-size: 14px;
  color: #f97316;
  font-weight: 500;
}

.expand-content {
  padding: 12px 16px;
  background: #f9fafb;
  border-radius: 8px;
  margin: 8px 0;
}

.platform-tabs {
  margin-bottom: 12px;
}

.platform-data {
  min-height: 60px;
}

.platform-row {
  display: flex;
  gap: 24px;
  padding: 8px 0;
  border-bottom: 1px solid #e5e7eb;
}

.platform-row:last-child {
  border-bottom: none;
}

.pf-name {
  font-weight: 500;
  width: 80px;
}

.pf-impressions, .pf-visitors, .pf-cost, .pf-orders {
  font-size: 13px;
  color: #6b7280;
  min-width: 100px;
}

.platform-detail {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.detail-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.detail-row .label {
  font-size: 12px;
  color: #9ca3af;
}

.detail-row .value {
  font-size: 14px;
  font-weight: 500;
  color: #374151;
}
</style>
